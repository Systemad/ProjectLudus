<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="https://api.nuget.org/v3/index.json" value="https://api.nuget.org/v3/index.json" />
    <add key="local" value="D:\LocalNugetPackages" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="https://api.nuget.org/v3/index.json">
      <package pattern="*" />
    </packageSource>

	<packageSource key="local">
    	<package pattern="EFCore.ParadeDB.*" />
  	</packageSource>
  </packageSourceMapping>
</configuration>