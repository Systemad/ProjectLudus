{
  "text_fields": {
    "name": {
      "fast": true,
      "tokenizer": {
        "type": "ngram",
        "min_gram": 2,
        "max_gram": 3,
        "prefix_only": false
      }
    },
    "numeric_fields": {
      "rating": {
        "fast": "true"
      },
      "rating_count": {
        "fast": "true"
      },
      "total_rating": {
        "fast": "true"
      },
      "total_rating_count": {
        "fast": "true"
      }
    },
    "datetime_fields": {
      "release_date": {
        "fast": true
      }
    }
  },
  "fields": {
    "id_done": "int PRIMARY KEY",
    "name_done": "varchar(80) NOT NULL",
    "release_date": "timestamptz",
    "game_type": "int",
    "platforms": "bigint[]",
    "game_engines": "bigint[]",
    "genres": "bigint[]",
    "themes": "bigint[]",
    "rating": "double precision",
    "rating_count": "double precision",
    "total_rating": "double precision",
    "total_rating_count": "double precision",
    "raw_data": "jsonb"
  }
}

