{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SteamWebAPIKey": "",
  "ReverseProxy": {
    "Routes": {
      "blazor": {
        "ClusterId": "blazor",
        "Match": {"Path":  "/{**catch-all}"}
      },
      "api": {
        "ClusterId": "api",
        "Match": {"Path":  "/api/{**catch-all}"}
      }
    },
    "Clusters": {
      "blazor": {
        "Destinations": {
          "blazor": {"Address":  "https://localhost:7152"}
        }
      },
      "api": {
        "Destinations": {
          "api": {"Address":  "https://localhost:7211"}
        }
      }
    }
  }
}
