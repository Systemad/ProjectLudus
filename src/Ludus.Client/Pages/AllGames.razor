@page "/games"
@using Ludus.Client.Features.Games.Components

<MudContainer MaxWidth="MaxWidth.Large">
    <MudStack>
        <MudStack Row="true">
            <MudTextField @bind-Value="SearchFilters.TextValue" Label="Game name" Variant="Variant.Text"></MudTextField>
            <MudButton Variant="Variant.Filled" Class="rounded-lg" DropShadow="false" OnClick="SearchGamesAsync">Search
            </MudButton>
        </MudStack>

        <MudStack Row="true">
            @if (Filters is not null)
            {
                if (Filters.Platforms is not null)
                {
                    <MudSelect Margin="Margin.Dense" Class="rounded-lg" Dense="true" T="PlatformFilter"
                               @bind-SelectedValues="@SearchFilters._selectedPlatforms"
                               Label="Platforms"
                               Variant="Variant.Filled"
                               MultiSelection="true"
                               ToStringFunc="g => g.Name">
                        @foreach (var gen in Filters.Platforms)
                        {
                            <MudSelectItem T="PlatformFilter" Value="@gen">@gen.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                if (Filters.Genres is not null)
                {
                    <MudSelect Margin="Margin.Dense" Dense="true" T="GenreFilter"
                               @bind-SelectedValues="@SearchFilters._selectedGenres"
                               Label="Genres"
                               Variant="Variant.Filled"
                               MultiSelection="true"
                               ToStringFunc="g => g.Name">
                        @foreach (var gen in Filters.Genres)
                        {
                            <MudSelectItem T="GenreFilter" Value="@gen">@gen.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                if (Filters.GameTypes is not null)
                {
                    <MudSelect Margin="Margin.Dense" Dense="true" T="GameTypeFilter"
                               @bind-SelectedValues="@SearchFilters._selectedGameTypes"
                               Label="Game Type"
                               Variant="Variant.Filled"
                               MultiSelection="true"
                               ToStringFunc="g => g.Name">
                        @foreach (var gen in Filters.GameTypes)
                        {
                            <MudSelectItem T="GameTypeFilter" Value="@gen">@gen.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                if (Filters.GameModes is not null)
                {
                    <MudSelect Margin="Margin.Dense" Dense="true" T="GameModeFilter"
                               @bind-SelectedValues="@SearchFilters._selectedGameModes"
                               Label="Game Modes"
                               Variant="Variant.Filled"
                               MultiSelection="true"
                               ToStringFunc="g => g.Name">
                        @foreach (var gen in Filters.GameModes)
                        {
                            <MudSelectItem T="GameModeFilter" Value="@gen">@gen.Name</MudSelectItem>
                        }
                    </MudSelect>
                }

                if (Filters.Themes is not null)
                {
                    <MudSelect Margin="Margin.Dense" Dense="true" T="ThemeFilter"
                               @bind-SelectedValues="@SearchFilters._selectedThemes"
                               Label="Themes"
                               Variant="Variant.Filled"
                               MultiSelection="true"
                               ToStringFunc="g => g.Name">
                        @foreach (var gen in Filters.Themes)
                        {
                            <MudSelectItem T="ThemeFilter" Value="@gen">@gen.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
            }
        </MudStack>
        @if (FetchedGames is not null)
        {
            <MudGrid Justify="Justify.FlexStart" Spacing="4">

                @if (FetchedGames.Games is not null)
                {
                    @foreach (var game in Games)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="2" xl="2">
                            <GameCard Game="@game"/>
                        </MudItem>
                    }

                    @if (FetchedGames.IsLastPage)
                    {
                        <MudItem xs="12" sm="12" md="12" lg="12" xl="12">
                            <MudText>All games have been loaded</MudText>
                        </MudItem>
                    }
                    else
                    {
                        <MudItem xs="12" sm="12" md="12" lg="12" xl="12">
                            <MudButton DropShadow="false" FullWidth="true" Variant="Variant.Filled" OnClick="LoadMoreGamesAsync">
                                Load more
                            </MudButton>
                        </MudItem>
                    }
                }
                else
                {
                    @for (int i = 0; i < 10; i++)
                    {
                        <MudItem xs="3">
                            <MudCard Elevation="0" Class="rounded-lg"
                                     Style="background: var(--mud-palette-background-gray); height: 100%">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px"/>
                                <MudCardContent>
                                    <MudSkeleton Width="30%" Height="42px;"/>
                                    <MudSkeleton Width="80%"/>
                                    <MudSkeleton Width="100%"/>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudSkeleton Width="64px" Height="40px" Class="ml-2"/>
                                    <MudSkeleton Width="105px" Height="40px" Class="ml-3"/>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                }

            </MudGrid>
        }

    </MudStack>
</MudContainer>