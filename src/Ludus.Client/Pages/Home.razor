@page "/"
@using System.Security.Claims
@using Ludus.Client.DaisyUI.Button
@using Ludus.Client.DaisyUI.Badge
@using Ludus.Client.DaisyUI.Status

<PageTitle>Home</PageTitle>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-4 px-4 py-4">
    @for (var i = 0; i < 10; i++)
    {
        <div class="d-card bg-base-100 w-full shadow-sm">
            <figure>
                <img
                    src="https://img.daisyui.com/images/stock/photo-1606107557195-0e29a4b5b4aa.webp"
                    alt="Shoes" />
            </figure>
            <div class="d-card-body">
                <h2 class="d-card-title">
                    Card Title
                </h2>
                <p>A card component has a figure, a body part, and inside body there are title and actions parts</p>

                <DaisyStatus Animation="DaisyStatus.Animations.Bounce" Color="DaisyStatus.Colors.Error" Size="DaisyStatus.Sizes.LG"></DaisyStatus>
                <DaisyBadge Size="DaisyBadge.Sizes.LG" Variant="DaisyBadge.Variants.Soft" Color="DaisyBadge.Colors.Neutral">Hello</DaisyBadge>
                <div class="d-card-actions justify-end">
                    <DaisyButton Color="DaisyButton.Colors.Primary" Size="DaisyButton.Sizes.MD">Default</DaisyButton>
                </div>
            </div>
        </div>
    }
</div>

