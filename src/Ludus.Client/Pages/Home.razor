@page "/"
@using System.Security.Claims

<PageTitle>Home</PageTitle>
<!-- Search Input -->
<input type="text" class="border p-2 rounded mb-4" placeholder="Search..." @bind="searchText" />

<!-- Card Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    @foreach (var card in filteredCards)
    {
        <div class="border p-4 rounded-lg shadow-md">
            <h3 class="font-semibold text-lg">@card.Title</h3>
            <p class="text-sm text-gray-600">@card.Description</p>
        </div>
    }
</div>

<!-- Pagination -->
<div class="flex justify-center mt-4">
    <button class="border px-4 py-2 rounded" @onclick="PrevPage" disabled="@(!CanGoPrev)">Previous</button>
    <button class="border px-4 py-2 rounded" @onclick="NextPage" disabled="@(!CanGoNext)">Next</button>
</div>

