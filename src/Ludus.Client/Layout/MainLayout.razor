@using System.Security.Claims
@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudTypographyProvider/>
<MudLayout>
    <!--
    <MudAppBar Elevation="0" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())"/>
        <MudText Typo="Typo.h5" Class="ml-3">Application</MudText>
        <MudSpacer/>
        <MudIconButton Icon="@(DarkLightModeButtonIcon)" Color="Color.Inherit" OnClick="@DarkModeToggle"/>
        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" Edge="Edge.End"/>
    </MudAppBar>
    -->
    <MudDrawer Anchor="Anchor.Left" @bind-open="@_drawerOpen" Variant="DrawerVariant.Persistent">
        <MudStack Class="mud-height-full">
            <MudText Typo="Typo.h5" Class="pa-2 my-4">Ludus</MudText>

            <NavMenu/>

            <MudDivider DividerType="DividerType.Middle"/>

            <LuMenu/>

            <MudSpacer/>
            <MudDivider DividerType="DividerType.Middle"/>
            <MudPaper Class="pa-2" Elevation="0">

                <AuthorizeView>
                    <NotAuthorized>
                        <a href="/signin">
                            <img src="/img/sits_small.png"/>
                        </a>
                    </NotAuthorized>

                    <Authorized>
                        @if (UserService.UserModel is not null)
                        {
                            <MudStack Row="true">
                                <MudAvatar Size="Size.Large" Rounded="true">
                                        <MudImage Src="@GetImageSrc(@UserService.UserModel.UserImage.ContentType, UserService.UserModel.UserImage.Content)"></MudImage>
                                </MudAvatar>
                                <MudStack Justify="Justify.Center" Spacing="0">
                                    <MudText Typo="Typo.body1">@UserService.UserModel.Name</MudText>
                                    <MudLink Href="/logout">Logout</MudLink>
                                </MudStack>
                            </MudStack>
                        }
                    </Authorized>
                </AuthorizeView>
            </MudPaper>
        </MudStack>
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @if (LoadingService.IsLoading)
        {
            <div class="fixed animated-background d-flex flex-column align-center justify-center mud-theme-secondary" style="width: 100vw; height: 100vh; z-index: 9999; background: linear-gradient(45deg, #E73C7E, #23A6D5, #E73C7E); background-size: 400%;">
                <MudProgressCircular Style="color: white !important" Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else
        {
            @Body
        }
    </MudMainContent>
</MudLayout>


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
